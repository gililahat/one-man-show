rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Business logos — publicly readable (appear on public quotes), owner-only write
    match /users/{userId}/logo/{file=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024              // 2 MB
        && request.resource.contentType.matches('image/.*');
    }

    // Private per-user files (future: project photos, expense receipts)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny anything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
